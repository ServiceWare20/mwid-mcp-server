# Example environment configuration for MWID MCP Server
# Copy this file to .env and fill in your values

# Backend API Configuration
MWID_API_URL=http://localhost:8080/api/v1

# Authentication Method (jwt, supabase, or google)
MWID_AUTH_METHOD=jwt

# JWT Authentication
MWID_JWT_TOKEN=

# Supabase Authentication (if using supabase)
MWID_SUPABASE_URL=
MWID_SUPABASE_KEY=
MWID_SUPABASE_EMAIL=
MWID_SUPABASE_PASSWORD=

# Google OAuth (if using google)
MWID_GOOGLE_ACCESS_TOKEN=

# Request timeout in seconds
MWID_REQUEST_TIMEOUT=30

# Debug mode
MWID_DEBUG=false

# External API (sales & investors)
MWID_EXTERNAL_API_URL=https://mwid.up.railway.app/api/v1/external
MWID_EXTERNAL_API_KEY=

# Port (Railway will set this automatically)
PORT=8000
